<!DOCTYPE html>
<html lang="zh-CN">
 <%- include('../templates/header.ejs') %>
 <body>
    <div class="logo"></div>
    <main id="main" class="main">
        <div class="window-body">
            <menu role="tablist"></menu>
            <div class="window" role="tabpanel">
                <div class="window-body message-page">

                    <!-- 留言提交表单 -->
                    <div id="msg-form-box" class="message-form-box">
                        <div class="message-form-body">
                            <!-- Netlify Forms 检测标记 -->
                            <form id="msg-form" name="guestbook" method="POST"
                                  data-netlify="true" data-netlify-honeypot="bot-field">
                                <input type="hidden" name="form-name" value="guestbook">
                                <!-- 蜜罐字段（防垃圾提交，对用户不可见） -->
                                <p style="display:none">
                                    <label>Do not fill this: <input name="bot-field"></label>
                                </p>
                                <div class="field-row-stacked">
                                    <label for="msg-nickname" data-lang-id="msg_nickname_label"></label>
                                    <input id="msg-nickname" name="nickname" type="text"
                                           maxlength="30" data-lang-placeholder="msg_nickname_placeholder">
                                </div>
                                <div class="field-row-stacked" style="margin-top:8px;">
                                    <label for="msg-content" data-lang-id="msg_content_label"></label>
                                    <textarea id="msg-content" name="message" rows="4"
                                              maxlength="500" data-lang-placeholder="msg_content_placeholder"></textarea>
                                </div>
                                <div class="message-form-footer">
                                    <span class="msg-char-counter"><span id="msg-char-count">0</span> / 500</span>
                                    <button type="submit" id="msg-submit-btn" data-lang-id="msg_submit_btn"></button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- 提交成功面板（默认隐藏） -->
                    <div id="msg-success" class="msg-success-panel" style="display:none;">
                        <div class="msg-success-icon">&#10003;</div>
                        <p class="msg-success-title" data-lang-id="msg_success_title"></p>
                        <p class="msg-success-body" data-lang-id="msg_success_body"></p>
                        <button id="msg-again-btn" data-lang-id="msg_submit_again"></button>
                    </div>

                </div>
            </div>
        </div>
    </main>
</body>
<%- include('../templates/function.ejs') %>
</html>
